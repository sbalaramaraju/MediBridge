{
  "entities": {
    "EmergencyCard": {
      "title": "EmergencyCard",
      "description": "A structured medical emergency action card generated from unstructured input.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who created the card." },
        "situation": { "type": "string", "description": "Brief classification of the medical situation." },
        "patientSummary": {
          "type": "object",
          "properties": {
            "age": { "type": "string" },
            "conditions": { "type": "array", "items": { "type": "string" } },
            "medications": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["age", "conditions", "medications"]
        },
        "actions": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "rawInput": { "type": "string" }
      },
      "required": ["userId", "situation", "patientSummary", "actions", "warnings", "language", "createdAt"]
    }
  },
  "firestore": {
    "/emergencyCards/{cardId}": {
      "schema": "EmergencyCard",
      "description": "Collection of emergency action cards."
    }
  }
}
