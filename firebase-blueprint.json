{
  "entities": {
    "EmergencyCard": {
      "title": "Emergency Action Card",
      "description": "A structured medical context card generated from unstructured input.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "patientSummary": {
          "type": "object",
          "properties": {
            "age": { "type": "string" },
            "conditions": { "type": "array", "items": { "type": "string" } },
            "medications": { "type": "array", "items": { "type": "string" } }
          }
        },
        "situation": { "type": "string" },
        "actions": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "rawInput": { "type": "string" },
        "language": { "type": "string" }
      },
      "required": ["userId", "createdAt", "situation", "actions"]
    }
  },
  "firestore": {
    "/emergencyCards/{cardId}": {
      "schema": "EmergencyCard",
      "description": "Collection of generated emergency action cards."
    }
  }
}
